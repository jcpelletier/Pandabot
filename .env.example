# --- Required ---
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=123456789012345678
ANTHROPIC_API_KEY=sk-ant-...

# --- Jenkins ---
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token

# --- Webhook (Jenkins → bot notifications) ---
WEBHOOK_PORT=8765
WEBHOOK_SECRET=your-webhook-secret

# --- Network ---
TAILSCALE_IP=100.x.x.x

# --- Jellyfin ---
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=your-jellyfin-api-key

# --- Azure App Insights (optional — needed for query_ripping: recent_rips and telemetry) ---
APPINSIGHTS_APP_ID=your-app-insights-application-id
APPINSIGHTS_IKEY=your-instrumentation-key
APPINSIGHTS_ENDPOINT=https://eastus-8.in.applicationinsights.azure.com/v2/track
AZURE_TENANT_ID=your-entra-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-app-registration-client-secret

# --- Storage paths ---
STAGING_PATH=/mnt/media/Video
MEDIA_PATH=/mnt/media/Media

# --- Proactive alerts ---
DISK_ALERT_THRESHOLD_PCT=85
DISK_ALERT_PATH=/mnt/media
WATCHDOG_SERVICES=jellyfin,sunshine

# --- Feature flags (set to false to disable entire subsystems) ---
ENABLE_JELLYFIN=true
ENABLE_JENKINS=true
ENABLE_RIPPING=true
ENABLE_SMART=true

# --- Bot identity ---
BOT_NAME=Panda
BOT_EMOJI=🐼

# --- Server description ---
# Leave SERVER_DESCRIPTION blank to auto-build from feature flags.
# Set it to a plain-English paragraph describing your server for the system prompt.
SERVER_DESCRIPTION=
HARDWARE_DESCRIPTION=NVIDIA GTX 970 (4 GB VRAM), 2 TB NTFS HDD at /mnt/media

# --- Timezone (used in system prompt and timestamp display) ---
TZ_NAME=America/New_York (Eastern Time, EDT/EST)

# --- Service whitelists (comma-separated; defaults match panda config) ---
DOCKER_LOG_CONTAINERS=jellyfin,jenkins,excalidraw,excalidraw-room
SYSTEMD_SERVICES=sunshine,tailscaled,cockpit,ssh
RESTARTABLE_CONTAINERS=jellyfin,jenkins,excalidraw,excalidraw-room
FILE_LOGS=rip-video:/var/log/rip-video.log,rip-cd:/var/log/rip-cd.log
JENKINS_JOBS=Login_Test,Process_Movies,Nightly_Convert

# --- SMART drive devices (device:label, comma-separated) ---
SMART_DEVICES=/dev/sda:SanDisk SSD PLUS (boot),/dev/sdb:Seagate ST4000DM004 (media)

# --- AI Crawl Analytics (optional — custom HTTP analytics endpoint, off by default) ---
# ENABLE_CRAWL_ANALYTICS=true
# CRAWL_ANALYTICS_URL=https://your-analytics-endpoint.example.com
# CRAWL_ANALYTICS_TOKEN=your-admin-token

# --- TTS / Voice (optional — Kokoro-82M local TTS via Docker at port 8880) ---
# Set ENABLE_TTS=true and run kokoro/docker-compose.yml to enable voice responses.
# Requires ffmpeg installed on the host and the bot token to have voice permissions.
# ENABLE_TTS=true
# TTS_URL=http://localhost:8880
# TTS_VOICE=af_heart
# TTS_IDLE_TIMEOUT_SECS=300
# TTS_AUTO_JOIN_CHANNEL_ID=123456789012345678  # voice channel ID to watch; bot joins on entry, leaves when empty
