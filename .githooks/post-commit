#!/bin/sh
# Tag the commit with the current version so GitHub has a browseable history.
# Tags are pushed automatically alongside commits because push.followTags=true
# is set in this repo's git config.
REPO="$(git rev-parse --show-toplevel)"
VERSION=$(cat "$REPO/VERSION" | tr -d '[:space:]')
TAG="v${VERSION}"

if git tag "$TAG" 2>/dev/null; then
    echo "Tagged: ${TAG}"
else
    echo "Tag ${TAG} already exists — skipping."
fi
